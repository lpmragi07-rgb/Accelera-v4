# ============================================================
# LIGARAUT — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha com seus valores.
# NUNCA comite o .env.local (já está no .gitignore).
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_publica
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role_secreta

# --- API4Com ---
# Token de API gerado no painel (Authorization). Veja developers.api4com.com/authentication
API4COM_TOKEN=seu_token_api4com
# Base da API (padrão abaixo; só mude se a API4Com instruir)
API4COM_BASE_URL=https://api.api4com.com/api/v1
# Código identificador da integração (gateway) usado no metadata/webhook
API4COM_GATEWAY=ligaraut
# Segredo aleatório que você inventa: protege o webhook (vai na URL ?secret=...)
API4COM_WEBHOOK_SECRET=troque_por_um_valor_aleatorio_forte

# --- App ---
# URL pública que a API4Com usa para alcançar o webhook.
# Dev: URL do ngrok (ex.: https://abc123.ngrok-free.app)
# Prod: URL da Vercel (ex.: https://ligaraut.vercel.app)
APP_BASE_URL=https://abc123.ngrok-free.app
